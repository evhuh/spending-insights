# PostgreSQL connection for the app database
DATABASE_URL=postgresql://user:password@localhost:5432/finance_tracker

# Separate local test database — self-tests run against this, never real data
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/finance_tracker_test

# AI categorization fallback
OPENAI_API_KEY=
# Optional: override the model used for categorization (default gpt-4o-mini)
# OPENAI_MODEL=

# Notion monthly report sync
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Python PDF extractor service
EXTRACTOR_URL=http://localhost:8000
